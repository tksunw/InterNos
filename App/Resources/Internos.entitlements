<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime blocks microphone access for non-sandboxed apps unless this
	     entitlement is present. Without it the TCC prompt fires but no usable grant
	     persists and the app never appears in the Microphone privacy pane. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
